{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "COREPACK_HOME"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "GRAD_PROJECT_URL",
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
